/* geo-insight/pages/diagnosis/diagnosis.wxss */

/* 基础样式 */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12px;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 10rpx;
}

/* 输入区域 */
.input-section {
  background: white;
  border-radius: 12px;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.input-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.input {
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  padding: 20rpx;
  font-size: 28rpx;
}

.textarea {
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  padding: 20rpx;
  font-size: 28rpx;
  min-height: 150rpx;
  width: 100%;
}

.checkbox-item {
  display: inline-block;
  margin-right: 30rpx;
  margin-bottom: 15rpx;
}

.diagnose-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 25px;
  padding: 25rpx 0;
  font-size: 32rpx;
  margin-top: 20rpx;
}

/* 健康评分 */
.score-section {
  background: white;
  border-radius: 12px;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.score-card {
  text-align: center;
  margin-bottom: 30rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border: 10rpx solid;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-level {
  font-size: 48rpx;
  font-weight: bold;
}

.score-value {
  font-size: 36rpx;
  color: #666;
}

.score-title {
  font-size: 28rpx;
  color: #666;
}

.score-breakdown {
  display: flex;
  justify-content: space-around;
  border-top: 1px solid #eee;
  padding-top: 30rpx;
}

.breakdown-item {
  text-align: center;
}

.breakdown-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.breakdown-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
}

/* 结果区域 */
.result-section {
  background: white;
  border-radius: 12px;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2px solid #667eea;
}

.platform-list {
  margin-bottom: 30rpx;
}

.platform-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 8px;
  margin-bottom: 15rpx;
}

.platform-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.platform-name {
  font-size: 30rpx;
  font-weight: bold;
}

.platform-badge {
  font-size: 22rpx;
  padding: 5rpx 15rpx;
  border-radius: 20px;
}

.platform-badge.recommended {
  background: #d9f7be;
  color: #52c41a;
}

.platform-badge.not-recommended {
  background: #fff1f0;
  color: #ff4d4f;
}

.platform-info {
  font-size: 26rpx;
  color: #666;
}

/* 关键词覆盖 */
.keyword-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}

.keyword-item {
  display: flex;
  align-items: center;
  background: #f0f0f0;
  padding: 10rpx 20rpx;
  border-radius: 20px;
  margin-right: 15rpx;
  margin-bottom: 15rpx;
}

.keyword-name {
  font-size: 26rpx;
  color: #333;
  margin-right: 10rpx;
}

.keyword-rate {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
}

/* 优化建议 */
.suggestion-list {
  margin-bottom: 30rpx;
}

.suggestion-item {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8px;
  margin-bottom: 15rpx;
}

.suggestion-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.priority {
  font-size: 22rpx;
  padding: 5rpx 15rpx;
  border-radius: 20px;
  margin-right: 15rpx;
}

.priority.HIGH {
  background: #fff1f0;
  color: #ff4d4f;
}

.priority.MEDIUM {
  background: #fff7e6;
  color: #fa8c16;
}

.priority.LOW {
  background: #f0f0f0;
  color: #999;
}

.suggestion-type {
  font-size: 28rpx;
  font-weight: bold;
}

.suggestion-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
