# 好易易GEO 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ⚠️ 请勿将 .env 文件提交到版本控制系统

# ============ 应用配置 ============
# 应用名称
APP_NAME=geo-insight
APP_ENV=production

# ============ DeepSeek API 配置 ============
# DeepSeek API密钥 (必填)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API地址
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# 使用的模型
DEEPSEEK_MODEL=deepseek-chat

# ============ 数据库配置 ============
# SQLite数据库路径 (Docker容器内)
DATABASE_PATH=/app/data/geo.db

# ============ Redis配置 ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============ 服务端口配置 ============
# 前端Nginx端口 (外部访问端口)
FRONTEND_PORT=80

# 后端API端口 (Docker内部5000,映射到此端口)
BACKEND_PORT=5000

# Redis端口
REDIS_EXPOSE_PORT=6379

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_MAX_SIZE=100M
LOG_MAX_FILES=10

# ============ 安全配置 ============
# JWT密钥 (用于生产环境)
JWT_SECRET=your-jwt-secret-key-change-in-production

# CORS允许的源 (生产环境应指定具体域名)
CORS_ORIGINS=http://localhost,http://localhost:5173,https://your-domain.com

# ============ 自动化任务配置 ============
# 自动化采集开关
AUTO_COLLECTOR_ENABLED=true
AUTO_COLLECTOR_INTERVAL=3600

# ============ 监控配置 ============
# 健康检查
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
