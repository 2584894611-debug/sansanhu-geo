# Docker构建忽略文件
# 不需要复制到镜像中的文件和目录

# ============ Git ============
.git
.gitignore
.gitattributes

# ============ IDE和编辑器 ============
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ============ Python缓存 ============
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.env
.venv
venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ============ Node.js ============
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ============ 测试和文档 ============
*.md
!requirements.txt
LICENSE
.env.example
tests/
docs/
examples/

# ============ 构建产物(前端单独处理) ============
web/dist/
web/node_modules/
web/.DS_Store

# ============ 日志和临时文件 ============
*.log
logs/
*.tmp
*.bak
*.swp
temp/

# ============ 开发文件 ============
docker-compose*.yml
Dockerfile*
.dockerignore
start.sh
deploy/
*.sh
Makefile

# ============ 数据库文件(运行时挂载) ============
*.db
*.db-journal
*.sqlite
*.sqlite3

# ============ 服务器配置 ============
server/
tasks/
components/
pages/
utils/
templates/
cloudfunctions/
