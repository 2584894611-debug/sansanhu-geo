# ==================== 免费诊断辅助函数 ====================
def save_lead(brand, industry, phone, wechat, company, device_id, geo_score=0):
    """保存免费诊断线索"""
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute("""
            INSERT INTO leads (brand, industry, phone, wechat, company, device_id, geo_score)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        """, (brand, industry, phone, wechat, company, device_id, geo_score))
        conn.commit()
        return c.lastrowid


# ==================== 报告存储 ====================
FREE_REPORT_TTL_DAYS = 7
PAID_REPORT_TTL_DAYS = 90

def save_report(phone, brand, industry, report_data, is_free=True):
    """保存报告到数据库"""
    import json
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "INSERT INTO saved_reports (phone, brand, industry, report_data, is_free) VALUES (?, ?, ?, ?, ?)",
            (phone, brand, industry, json.dumps(report_data, ensure_ascii=False), 1 if is_free else 0)
        )
        conn.commit()
        return cur.lastrowid

def get_cached_report(phone, brand):
    """获取缓存的报告（7天内同品牌不重复分析）"""
    import json
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "SELECT id, report_data, created_at, is_free FROM saved_reports WHERE phone = ? AND brand = ? ORDER BY created_at DESC LIMIT 1",
            (phone, brand)
        )
        row = cur.fetchone()
        if not row:
            return None
        # Check TTL
        created = datetime.fromisoformat(row["created_at"])
        ttl_days = FREE_REPORT_TTL_DAYS if row["is_free"] else PAID_REPORT_TTL_DAYS
        if (datetime.now() - created).days > ttl_days:
            return None
        return json.loads(row["report_data"])

def get_report_history(phone, limit=20):
    """获取手机号的报告历史"""
    import json
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "SELECT id, brand, industry, created_at, is_free, report_data FROM saved_reports WHERE phone = ? ORDER BY created_at DESC LIMIT ?",
            (phone, limit)
        )
        rows = cur.fetchall()
        result = []
        for r in rows:
            item = {"id": r["id"], "brand": r["brand"], "industry": r["industry"], "created_at": r["created_at"], "is_free": r["is_free"]}
            try:
                rd = json.loads(r["report_data"]) if r["report_data"] else {}
                item["score"] = rd.get("geo_score", 0)
            except:
                item["score"] = 0
            result.append(item)
        return result

def get_report_by_id(report_id, phone):
    """按ID获取报告（需验证手机号）"""
    import json
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "SELECT report_data, brand, industry, created_at, is_free FROM saved_reports WHERE id = ? AND phone = ?",
            (report_id, phone)
        )
        row = cur.fetchone()
        if not row:
            return None
        return {
            "data": json.loads(row["report_data"]),
            "brand": row["brand"],
            "industry": row["industry"],
            "created_at": row["created_at"],
            "is_free": row["is_free"]
        }

def generate_word_report(report_data, brand, industry, is_free=True):
    """生成Word报告"""
    from docx import Document
    from docx.shared import Pt, Inches, Cm, RGBColor
    from docx.enum.text import WD_ALIGN_PARAGRAPH
    from io import BytesIO
    
    doc = Document()
    
    # 设置默认字体
    style = doc.styles['Normal']
    font = style.font
    font.name = '微软雅黑'
    font.size = Pt(11)
    
    # 标题
    title = doc.add_heading('', level=0)
    run = title.add_run('三三狐GEO诊断报告')
    run.font.size = Pt(24)
    run.font.color.rgb = RGBColor(0x1A, 0x56, 0xDB)
    title.alignment = WD_ALIGN_PARAGRAPH.CENTER
    
    # 基本信息
    doc.add_paragraph('')
    info = doc.add_paragraph()
    info.add_run('品牌：').bold = True
    info.add_run(brand)
    info = doc.add_paragraph()
    info.add_run('行业：').bold = True
    info.add_run(industry or '-')
    info = doc.add_paragraph()
    info.add_run('分析时间：').bold = True
    info.add_run(datetime.now().strftime('%Y-%m-%d %H:%M'))
    
    # 水印（免费用户）
    if is_free:
        doc.add_paragraph('')
        wm = doc.add_paragraph()
        wm.alignment = WD_ALIGN_PARAGRAPH.CENTER
        run = wm.add_run('—— 由三三狐GEO提供 ——')
        run.font.color.rgb = RGBColor(0x99, 0x99, 0x99)
        run.font.size = Pt(9)
    
    doc.add_paragraph('')
    
    # 一、GEO评分
    doc.add_heading('一、GEO评分', level=1)
    scores = [
        ('综合评分', report_data.get('geo_score')),
        ('可见度', report_data.get('visibility_score')),
        ('推荐度', report_data.get('recommendation_score')),
        ('情感倾向', report_data.get('sentiment_score')),
    ]
    table = doc.add_table(rows=len(scores)+1, cols=2)
    table.style = 'Light Shading Accent 1'
    table.rows[0].cells[0].text = '指标'
    table.rows[0].cells[1].text = '评分'
    for i, (name, val) in enumerate(scores):
        table.rows[i+1].cells[0].text = name
        table.rows[i+1].cells[1].text = str(val or '-')
    
    doc.add_paragraph('')
    
    # 二、诊断分析
    diagnosis = report_data.get('diagnosis', [])
    if diagnosis:
        doc.add_heading('二、诊断分析', level=1)
        for i, d in enumerate(diagnosis):
            dtype = d.get('type', '诊断') if isinstance(d, dict) else '诊断'
            desc = d.get('description', str(d)) if isinstance(d, dict) else str(d)
            p = doc.add_paragraph()
            p.add_run(f'{i+1}. [{dtype}] ').bold = True
            p.add_run(desc)
    
    # 三、优化建议
    recs = report_data.get('recommendations', [])
    if is_free and recs:
        recs = recs[:1]
    if recs:
        doc.add_heading('三、优化建议', level=1)
        for i, r in enumerate(recs):
            if isinstance(r, dict):
                title_text = r.get('title', '')
                desc_text = r.get('description', '')
                action_text = r.get('action', '')
                p = doc.add_paragraph()
                p.add_run(f'{i+1}. {title_text}').bold = True
                if desc_text:
                    doc.add_paragraph(f'   {desc_text}')
                if action_text:
                    doc.add_paragraph(f'   行动建议：{action_text}')
            else:
                doc.add_paragraph(f'{i+1}. {r}')
    
    # 四、竞品对比（付费）
    competitors = report_data.get('competitors', [])
    if competitors and not is_free:
        doc.add_heading('四、竞品对比', level=1)
        for i, comp in enumerate(competitors):
            if isinstance(comp, dict):
                name = comp.get('name', '')
                score = comp.get('geo_score', '-')
                p = doc.add_paragraph()
                p.add_run(f'{i+1}. {name}').bold = True
                p.add_run(f'（评分：{score}）')
            else:
                doc.add_paragraph(f'{i+1}. {comp}')
    elif is_free:
        doc.add_heading('四、竞品对比', level=1)
        p = doc.add_paragraph()
        run = p.add_run('💡 升级付费版查看完整竞品对比分析')
        run.font.color.rgb = RGBColor(0x1A, 0x56, 0xDB)
    
    # 五、内容播种方案（付费）
    cs = report_data.get('content_strategy')
    if cs and not is_free:
        doc.add_heading('五、内容播种方案', level=1)
        if cs.get('keywords'):
            p = doc.add_paragraph()
            p.add_run('关键词：').bold = True
            p.add_run('、'.join(cs['keywords']))
        if cs.get('content_types'):
            p = doc.add_paragraph()
            p.add_run('内容类型：').bold = True
            p.add_run('、'.join(cs['content_types']))
        if cs.get('viral_titles'):
            p = doc.add_paragraph()
            p.add_run('爆款标题：').bold = True
            for i, t in enumerate(cs['viral_titles']):
                doc.add_paragraph(f'  {i+1}. {t}')
    elif is_free:
        doc.add_heading('五、内容播种方案', level=1)
        p = doc.add_paragraph()
        run = p.add_run('💡 升级付费版查看完整内容播种方案')
        run.font.color.rgb = RGBColor(0x1A, 0x56, 0xDB)
    
    # 页脚
    doc.add_paragraph('')
    doc.add_paragraph('')
    footer = doc.add_paragraph()
    footer.alignment = WD_ALIGN_PARAGRAPH.CENTER
    run = footer.add_run('报告由三三狐GEO生成 | https://xhpj.cloud')
    run.font.size = Pt(9)
    run.font.color.rgb = RGBColor(0x99, 0x99, 0x99)
    
    # 保存到BytesIO
    buffer = BytesIO()
    doc.save(buffer)
    buffer.seek(0)
    return buffer

ADMIN_SECRET = "ssfox-admin-2026"

def check_phone_premium(phone: str) -> bool:
    """检查手机号是否为付费用户"""
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "SELECT expires_at FROM premium_phones WHERE phone = ?",
            (phone,)
        )
        result = cur.fetchone()
        if result and result["expires_at"]:
            expires = datetime.fromisoformat(result["expires_at"])
            if expires > datetime.now():
                return True
    return False

def upgrade_phone(phone: str, days: int = 365, note: str = ""):
    """开通手机号付费权限"""
    expires_at = datetime.now().replace(year=datetime.now().year + (days // 365)).isoformat() if days >= 365 else (datetime.now().replace(day=1)).isoformat()
    # More precise: add days
    from datetime import timedelta
    expires_at = (datetime.now() + timedelta(days=days)).isoformat()
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "INSERT OR REPLACE INTO premium_phones (phone, expires_at, note) VALUES (?, ?, ?)",
            (phone, expires_at, note)
        )
        conn.commit()

def is_valid_phone(phone: str) -> bool:
    """校验手机号格式（11位，合法号段）"""
    if not phone or len(phone) != 11 or not phone.isdigit():
        return False
    valid_prefixes = ('13', '14', '15', '16', '17', '18', '19')
    return phone.startswith(valid_prefixes)

def check_phone_daily_limit(phone: str) -> bool:
    """检查手机号每日使用限制（3次/天）"""
    today = datetime.now().date().isoformat()
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "SELECT COUNT(*) as cnt FROM leads WHERE phone = ? AND date(created_at) = ?",
            (phone, today)
        )
        result = cur.fetchone()
        return result["cnt"] < FREE_DAILY_LIMIT

def check_brand_monthly_limit(brand, phone):
    """检查品牌月度使用限制（免费用户每月每品牌1次，按手机号）"""
    month = datetime.now().strftime("%Y-%m")
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute(
            "SELECT COUNT(*) as cnt FROM brand_monthly_usage WHERE brand = ? AND usage_month = ? AND phone = ?",
            (brand, month, phone)
        )
        result = c.fetchone()
        return result["cnt"] == 0

def record_brand_monthly_usage(brand, phone):
    """记录品牌月度使用"""
    month = datetime.now().strftime("%Y-%m")
    with get_db_connection() as conn:
        c = conn.cursor()
        try:
            c.execute(
                "INSERT INTO brand_monthly_usage (brand, usage_month, phone) VALUES (?, ?, ?)",
                (brand, month, phone)
            )
            conn.commit()
        except:
            pass

