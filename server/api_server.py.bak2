# ==================== 数据模型 ====================
class AnalyzeRequest(BaseModel):
    """分析请求模型"""
    type: str = Field(..., description="分析类型: brand_analysis/competitor_analysis/content_strategy")
    brand: str = Field(..., description="品牌/公司名称")
    industry: str = Field(default="通用", description="行业类型")
    device_id: str = Field(default="default", description="设备ID")
    phone: str = Field(default="", description="联系电话")
    wechat: str = Field(default="", description="微信号")
    company: str = Field(default="", description="公司名称")

class AnalyzeResponse(BaseModel):
    """分析响应模型"""
    success: bool
    data: Optional[Dict[str, Any]] = None
    ai_used: str = "DeepSeek"
    platforms_analyzed: List[str] = PLATFORMS
    error: Optional[str] = None
    is_full_report: bool = False

class UserStatusResponse(BaseModel):
    """用户状态响应"""
    is_premium: bool
    today_usage: int
    remaining: int
    token: str

# ==================== DeepSeek API 调用 ====================
async def call_deepseek(prompt: str, system_prompt: Optional[str] = None) -> str:
    """调用DeepSeek API生成内容"""
    headers = {
        "Authorization": f"Bearer {DEEPSEEK_API_KEY}",
        "Content-Type": "application/json"
    }
    
    messages = []
    if system_prompt:
        messages.append({"role": "system", "content": system_prompt})
    messages.append({"role": "user", "content": prompt})
    
    payload = {
        "model": DEEPSEEK_MODEL,
        "messages": messages,
        "temperature": 0.7,
        "max_tokens": 3000
    }
    
    async with httpx.AsyncClient(timeout=120.0) as client:
        response = await client.post(DEEPSEEK_API_URL, headers=headers, json=payload)
        response.raise_for_status()
        result = response.json()
        return result["choices"][0]["message"]["content"]


async def call_qwen(prompt: str, system_prompt: Optional[str] = None) -> str:
    """调用千问API - 用于真实AI搜索查询（双数据源）"""
    headers = {
        "Authorization": f"Bearer {QWEN_API_KEY}",
        "Content-Type": "application/json"
    }
    
    messages = []
    if system_prompt:
        messages.append({"role": "system", "content": system_prompt})
    messages.append({"role": "user", "content": prompt})
    
    payload = {
        "model": QWEN_MODEL,
        "messages": messages,
        "temperature": 0.3,
        "max_tokens": 2000
    }
    
    try:
        async with httpx.AsyncClient(timeout=60.0) as client:
            response = await client.post(QWEN_API_URL, headers=headers, json=payload)
            response.raise_for_status()
            result = response.json()
            return result["choices"][0]["message"]["content"]
    except Exception as e:
        print(f"千问API调用失败: {e}")
        return ""


async def query_ai_search_real(brand: str, industry: str) -> Dict[str, Any]:
    """真实调用多个AI搜索引擎，获取品牌在AI回答中的实际表现"""
    qwen_result = {"mentioned": False, "recommended": False, "sentiment": "unknown", "response_text": ""}
    
    # 构造用户会问的真实问题
    search_prompts = [
        f"推荐一下{industry}行业比较好的品牌",
        f"{industry}行业哪些品牌值得选择？",
    ]
    
    qwen_system = "你是一个AI助手，请根据你的知识真实回答用户的问题。不要编造，如果你知道就推荐，不知道就说不知道。"
    
    try:
        # 用千问做真实AI搜索查询
        responses = []
        for prompt in search_prompts:
            resp = await call_qwen(prompt, qwen_system)
            if resp:
                responses.append(resp)
        
        combined_text = " ".join(responses)
        qwen_result["response_text"] = combined_text[:500]  # 保存摘要
        
        # 分析品牌是否被提及
        brand_variants = [brand]
        # 常见品牌名变体处理
        if len(brand) > 2:
            brand_variants.append(brand[:2])  # 简称
        
        for variant in brand_variants:
            if variant in combined_text:
                qwen_result["mentioned"] = True
                break
        
        # 分析是否被推荐（正向语境）
        recommend_keywords = ["推荐", "值得", "不错", "好", "知名", "领先", "优秀", "首选"]
        if qwen_result["mentioned"]:
            # 找品牌附近的上下文
            for variant in brand_variants:
                idx = combined_text.find(variant)
                if idx >= 0:
                    context = combined_text[max(0, idx-30):min(len(combined_text), idx+len(variant)+30)]
                    for kw in recommend_keywords:
                        if kw in context:
                            qwen_result["recommended"] = True
                            break
                    # 简单情感判断
                    neg_keywords = ["不推荐", "差", "问题", "投诉", "避雷"]
                    for nk in neg_keywords:
                        if nk in context:
                            qwen_result["sentiment"] = "negative"
                            break
                    else:
                        if qwen_result["recommended"]:
                            qwen_result["sentiment"] = "positive"
                        else:
                            qwen_result["sentiment"] = "neutral"
                    break
        
    except Exception as e:
        print(f"千问真实查询失败: {e}")
    
    return {"qwen": qwen_result}


# ==================== 监测功能：实时多平台AI搜索监测 ====================

MONITOR_QUESTIONS = [
    "推荐一下{industry}比较好的品牌",
    "{industry}哪个品牌好？求推荐",
    "我想了解{industry}行业有哪些知名品牌",
]

PLATFORM_QUERIES = {
    "deepseek": {
        "system": "你是一个知识丰富的AI助手，请根据你的知识库真实回答。不要编造品牌，只推荐你确实知道的。如果知道就推荐，不知道就说不知道。",
        "temperature": 0.3,
        "max_tokens": 1500,
    },
    "qwen": {
        "system": "你是一个知识丰富的AI助手，请根据你的知识库真实回答。不要编造品牌，只推荐你确实知道的。如果知道就推荐，不知道就说不知道。",
        "temperature": 0.3,
        "max_tokens": 1500,
    },
}


async def monitor_brand_on_platform(brand: str, industry: str, platform: str) -> dict:
    """在单个AI平台上监测品牌可见度"""
    config = PLATFORM_QUERIES.get(platform)
    if not config:
        return {"error": f"unknown platform: {platform}"}
    
    questions = [q.format(industry=industry) for q in MONITOR_QUESTIONS]
    
    all_responses = []
    for q in questions:
        try:
            if platform == "deepseek":
                resp = await call_deepseek(q, config["system"])
            elif platform == "qwen":
                resp = await call_qwen(q, config["system"])
            else:
                continue
            if resp:
                all_responses.append({"question": q, "response": resp})
        except Exception as e:
            all_responses.append({"question": q, "error": str(e)})
    
    if not all_responses:
        return {"platform": platform, "mentioned": False, "score": 0, "excerpts": [], "error": "no responses"}
    
    combined_text = " ".join(r.get("response", "") for r in all_responses if "response" in r)
    
    mentioned = brand in combined_text
    if not mentioned and len(brand) > 2:
        mentioned = brand[:2] in combined_text or brand[-2:] in combined_text
    
    recommended = False
    sentiment = "unknown"
    excerpts = []
    
    if mentioned:
        for variant in [brand, brand[:2], brand[-2:]] if len(brand) > 2 else [brand]:
            start = 0
            while True:
                idx = combined_text.find(variant, start)
                if idx < 0:
                    break
                context_start = max(0, idx - 50)
                context_end = min(len(combined_text), idx + len(variant) + 80)
                excerpt = combined_text[context_start:context_end].strip()
                if excerpt and excerpt not in excerpts:
                    excerpts.append(excerpt)
                start = idx + len(variant)
                if len(excerpts) >= 3:
                    break
        
        recommend_words = ["推荐", "值得", "不错", "好", "知名", "领先", "优秀", "首选", "热门"]
        neg_words = ["不推荐", "差", "问题", "投诉", "避雷", "坑"]
        
        for excerpt in excerpts:
            has_pos = any(w in excerpt for w in recommend_words)
            has_neg = any(w in excerpt for w in neg_words)
            if has_pos and not has_neg:
                recommended = True
                sentiment = "positive"
                break
            elif has_neg:
                sentiment = "negative"
            elif sentiment == "unknown":
                sentiment = "neutral"
    
    if not mentioned:
        score = 0
    elif recommended:
        score = 90 + min(10, len(excerpts) * 3)
    elif sentiment == "positive":
        score = 70 + min(20, len(excerpts) * 5)
    elif sentiment == "neutral":
        score = 40 + min(30, len(excerpts) * 5)
    else:
        score = 20 + min(20, len(excerpts) * 5)
    
    return {
        "platform": platform,
        "mentioned": mentioned,
        "recommended": recommended,
        "sentiment": sentiment,
        "score": score,
        "excerpts": excerpts[:3],
        "response_count": len([r for r in all_responses if "response" in r]),
    }


async def run_brand_monitor(brand: str, industry: str = "") -> dict:
    """执行完整的品牌监测"""
    import asyncio
    
    if not industry:
        industry = "综合"
    
    platforms = list(PLATFORM_QUERIES.keys())
    tasks = [monitor_brand_on_platform(brand, industry, p) for p in platforms]
    results = await asyncio.gather(*tasks, return_exceptions=True)
    
    platform_details = {}
    for i, result in enumerate(results):
        if isinstance(result, Exception):
            platform_details[platforms[i]] = {"error": str(result), "mentioned": False, "score": 0}
        else:
            platform_details[platforms[i]] = result
    
    scores = [r.get("score", 0) for r in platform_details.values() if not r.get("error")]
    total_platforms = len(platforms)
    mentioned_count = sum(1 for r in platform_details.values() if r.get("mentioned"))
    recommended_count = sum(1 for r in platform_details.values() if r.get("recommended"))
    
    if scores:
        geo_score = int(sum(scores) / total_platforms)
    else:
        geo_score = 0
    
    # 竞品洞察
    competitor_insight = ""
    try:
        all_excerpts_text = ""
        for r in platform_details.values():
            excerpts = r.get("excerpts", [])
            all_excerpts_text += " ".join(excerpts) + " "
        
        if all_excerpts_text:
            comp_prompt = (
                '以下是一些AI搜索关于' + industry + '品牌推荐的部分回答片段：\n'
                + all_excerpts_text[:1000] + '\n\n'
                + '请列出其中被推荐的品牌名称（除了' + brand + '），如果没有其他品牌被提及则说"未发现竞品推荐"。只列出品牌名，用逗号分隔。'
            )
            competitor_insight = await call_deepseek(comp_prompt, "你是一个简洁的分析助手，只输出品牌名称列表。")
    except:
        competitor_insight = "分析失败"
    
    # AI优化建议
    ai_recommendation = ""
    try:
        rec_prompt = (
            '品牌「' + brand + '」在' + industry + '行业的GEO可见度评分为'
            + str(geo_score) + '分（满分100），在'
            + str(mentioned_count) + '/' + str(total_platforms) + '个AI平台被提及，在'
            + str(recommended_count) + '/' + str(total_platforms) + '个平台被推荐。请给出3条简洁的GEO优化建议，每条不超过30字。'
        )
        ai_recommendation = await call_deepseek(rec_prompt, "你是GEO优化专家，给出简洁可操作的建议。")
    except:
        ai_recommendation = "优化建议生成失败"
    
    # 存入数据库
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute("""
            INSERT INTO monitor_results (brand, industry, geo_score, platform_details, competitor_insight, ai_recommendation, query_questions, created_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))
        """, (
            brand, industry, geo_score,
            json.dumps(platform_details, ensure_ascii=False),
            competitor_insight,
            ai_recommendation,
            json.dumps([q.format(industry=industry) for q in MONITOR_QUESTIONS], ensure_ascii=False),
        ))
        monitor_id = c.lastrowid
        
        # 更新score_history用于趋势
        c.execute("""
            INSERT INTO score_history (brand, industry, geo_score, visibility_score, recommendation_score, sentiment_score, created_at)
            VALUES (?, ?, ?, ?, ?, ?, datetime('now'))
        """, (
            brand, industry, geo_score,
            int(mentioned_count / total_platforms * 100) if total_platforms else 0,
            int(recommended_count / total_platforms * 100) if total_platforms else 0,
            int(geo_score * 0.8),
        ))
        
        # 检查是否需要生成alert
        c.execute("""
            SELECT geo_score FROM score_history 
            WHERE brand = ? ORDER BY created_at DESC LIMIT 2
        """, (brand,))
        rows = c.fetchall()
        if len(rows) >= 2:
            prev_score = rows[1][0]
            diff = geo_score - prev_score
            if abs(diff) >= 10:
                alert_type = "rise" if diff > 0 else "fall"
                c.execute("""
                    INSERT INTO alerts (brand, alert_type, message, old_score, new_score, created_at)
                    VALUES (?, ?, ?, ?, ?, datetime('now'))
                """, (brand, alert_type, f"GEO评分{'上升' if diff > 0 else '下降'}{abs(diff)}分", prev_score, geo_score))
    
    return {
        "id": monitor_id,
        "brand": brand,
        "industry": industry,
        "geo_score": geo_score,
        "platform_details": platform_details,
        "mentioned_count": mentioned_count,
        "total_platforms": total_platforms,
        "recommended_count": recommended_count,
        "competitor_insight": competitor_insight,
        "ai_recommendation": ai_recommendation,
        "visibility_rate": f"{mentioned_count}/{total_platforms}",
        "recommendation_rate": f"{recommended_count}/{total_platforms}",
    }


