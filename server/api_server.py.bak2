# ==================== 监测功能 API ====================

class MonitorRequest(BaseModel):
    """监测请求模型"""
    brand: str = Field(..., description="品牌名称")
    industry: str = Field(default="综合", description="行业类型")
    device_id: str = Field(default="default", description="设备ID")

@app.post("/api/monitor/start")
async def start_monitor(req: MonitorRequest):
    """启动品牌GEO监测 - 实时查询多平台AI搜索引擎"""
    try:
        result = await run_brand_monitor(req.brand, req.industry)
        return {"success": True, "data": result}
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"监测执行失败: {str(e)}")

@app.get("/api/monitor/history")
async def get_monitor_history(brand: str = Query(default=None), limit: int = Query(default=10)):
    """获取监测历史"""
    with get_db_connection() as conn:
        c = conn.cursor()
        if brand:
            c.execute("SELECT * FROM monitor_results WHERE brand = ? ORDER BY created_at DESC LIMIT ?", (brand, limit))
        else:
            c.execute("SELECT * FROM monitor_results ORDER BY created_at DESC LIMIT ?", (limit,))
        results = [dict(row) for row in c.fetchall()]
        for r in results:
            try:
                r['platform_details'] = json.loads(r.get('platform_details', '{}'))
            except:
                r['platform_details'] = {}
        return {"success": True, "data": results}
