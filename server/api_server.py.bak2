@app.post("/api/analyze", response_model=AnalyzeResponse)
async def analyze(request: AnalyzeRequest):
    """核心分析接口"""
    valid_types = ["brand_analysis", "competitor_analysis", "content_strategy"]
    if request.type not in valid_types:
        raise HTTPException(
            status_code=400,
            detail=f"无效的分析类型。可选值: {valid_types}"
        )
    
    if not request.brand or len(request.brand.strip()) < 2:
        raise HTTPException(
            status_code=400,
            detail="品牌名称不能少于2个字符"
        )
    
    # 检查用户状态
    status = check_user_status(request.device_id)
    phone_is_premium = check_phone_premium(request.phone.strip()) if request.phone.strip() else False
    is_free = not status["is_premium"] and not phone_is_premium
    
    # 免费用户必须留手机号
    if is_free and not request.phone.strip():
        raise HTTPException(
            status_code=400,
            detail="免费诊断需提供手机号"
        )
    
    # 校验手机号格式
    if is_free and not is_valid_phone(request.phone.strip()):
        raise HTTPException(
            status_code=400,
            detail="请输入有效的手机号码（11位）"
        )
    
    # 免费用户每天3次（按手机号）
    if is_free and not check_phone_daily_limit(request.phone.strip()):
        raise HTTPException(
            status_code=429,
            detail="今日免费诊断次数已用完（每天3次），请明天再来"
        )
    
    # 免费用户每月每品牌限1次（按手机号）
    if is_free and not check_brand_monthly_limit(request.brand.strip(), request.phone.strip()):
        raise HTTPException(
            status_code=429,
            detail="该品牌本月免费诊断次数已用完，每月每品牌限1次"
        )
    
    # 检查7天内是否有缓存报告
    cached = get_cached_report(request.phone.strip(), request.brand.strip())
    if cached:
        cached.setdefault("_meta", {})["from_cache"] = True
        return {"success": True, "data": cached}
    
    try:
        # 根据分析类型选择提示词
        is_full = status["is_premium"] or phone_is_premium
        
        if request.type == "brand_analysis":
            prompt = get_brand_analysis_prompt(request.brand, request.industry, is_full)
        elif request.type == "competitor_analysis":
            prompt = get_competitor_analysis_prompt(request.brand, request.industry)
        else:
            prompt = get_content_strategy_prompt(request.brand, request.industry)
        
        # 双数据源并发调用：DeepSeek评分 + 千问真实搜索
        industry_name_map = {
            "catering": "餐饮美食", "realestate": "房产家居", "commerce": "商业综合体",
            "auto": "汽车交通", "tourism": "文旅景区", "education": "教育培训",
            "medical": "医疗健康", "finance": "金融理财", "retail": "零售消费",
            "internet": "互联网科技", "manufacturing": "制造工业",
            "realestate_service": "生活服务", "media": "传媒营销",
            "food": "食品饮料", "logistics": "物流仓储", "other": "其他行业"
        }
        industry_name = industry_name_map.get(request.industry, request.industry)
        
        import asyncio
        # 并发调用两个数据源
        ds_task = asyncio.create_task(call_deepseek(prompt, SYSTEM_PROMPT))
        qwen_task = asyncio.create_task(query_ai_search_real(request.brand.strip(), industry_name))
        
        # DeepSeek评分
        try:
            response_text = await ds_task
            analysis_data = safe_json_loads(response_text)
        except Exception as e:
            print(f"DeepSeek调用失败: {e}，使用模拟数据")
            analysis_data = generate_mock_analysis(request.brand, request.industry, is_full)
        
        # 千问真实搜索（并发执行，不阻塞DeepSeek）
        try:
            real_search_data = await qwen_task
            analysis_data["ai_search_real"] = real_search_data
            analysis_data["data_sources"] = ["DeepSeek(评分分析)", "千问(真实搜索)"]
        except Exception as e:
            print(f"千问双数据源查询失败: {e}")
            analysis_data["data_sources"] = ["DeepSeek(评分分析)"]
        
        # 保存报告到数据库
        report_id = save_report(request.phone.strip(), request.brand.strip(), request.industry, analysis_data, is_free)
        
        # 保存免费诊断线索
        if is_free:
            save_lead(
                request.brand.strip(), request.industry,
                request.phone.strip(), request.wechat.strip(),
                request.company.strip(), request.device_id,
                analysis_data.get("geo_score", 0)
            )
            record_brand_monthly_usage(request.brand.strip(), request.phone.strip())
        
        # 付费用户：生成内容播种方案
        if not is_free and request.type == "brand_analysis":
            try:
                cs_prompt = get_content_strategy_prompt(request.brand, request.industry)
                cs_text = await call_deepseek(cs_prompt, SYSTEM_PROMPT)
                cs_data = safe_json_loads(cs_text)
                analysis_data["content_strategy"] = {
                    "target_keywords": cs_data.get("target_keywords", []),
                    "content_types": cs_data.get("content_types", []),
                    "platforms": cs_data.get("platforms", []),
                    "sample_titles": cs_data.get("sample_titles", []),
                    "content_calendar": cs_data.get("content_calendar", ""),
                    "seo_tips": cs_data.get("seo_tips", []),
                    "trending_topics": cs_data.get("trending_topics", [])
                }
            except Exception as e:
                print(f"内容播种方案生成失败: {e}")
                analysis_data["content_strategy"] = None
        
        # 免费用户：只显示1条优化建议，不显示竞品对比和内容播种方案
        if is_free:
            if "recommendations" in analysis_data and isinstance(analysis_data["recommendations"], list):
                analysis_data["recommendations"] = analysis_data["recommendations"][:1]
            if "competitors" in analysis_data:
                analysis_data["competitors"] = []
            if "diagnosis" in analysis_data and isinstance(analysis_data["diagnosis"], list):
                analysis_data["diagnosis"] = analysis_data["diagnosis"][:1]
            if "content_strategy" in analysis_data:
                del analysis_data["content_strategy"]
        
        # 保存评分历史
        if request.type == "brand_analysis":
            save_score_history(request.brand, request.industry, {
                "geo_score": analysis_data.get("geo_score", 0),
                "visibility_score": analysis_data.get("visibility_score", 0),
                "recommendation_score": analysis_data.get("recommendation_score", 0),
                "sentiment_score": analysis_data.get("sentiment_score", 0)
            })
        
        # 保存分析记录
        save_analysis_record(request.device_id, analysis_data, is_full)
        
        # 增加使用次数（免费用户）
        if not status["is_premium"]:
            increment_usage(request.device_id)
        
        # 添加元数据
        analysis_data["_meta"] = {
            "brand": request.brand,
            "industry": request.industry,
            "analysis_type": request.type,
            "analyzed_at": datetime.now().isoformat(),
            "ai_model": DEEPSEEK_MODEL,
            "is_full_report": is_full,
            "is_free": is_free,
            "watermark": "由三三狐GEO提供" if is_free else None,
            "_report_id": report_id if "report_id" in dir() else None,
            "_query_phone": request.phone.strip()
        }
        
        return AnalyzeResponse(
            success=True,
            data=analysis_data,
            ai_used="DeepSeek",
            platforms_analyzed=PLATFORMS,
            is_full_report=is_full
        )
        
    except Exception as e:
        return AnalyzeResponse(
            success=False,
            error=f"分析失败: {str(e)}",
            platforms_analyzed=PLATFORMS
        )






# ==================== 报告历史与下载 ====================

@app.get("/api/reports/history")
async def report_history(phone: str = Query(..., description="手机号")):
    """获取手机号的报告历史列表"""
    if not is_valid_phone(phone):
        raise HTTPException(status_code=400, detail="手机号格式无效")
    reports = get_report_history(phone)
    return {"success": True, "data": reports}

@app.get("/api/reports/{report_id}")
async def get_report(report_id: int, phone: str = Query(..., description="手机号")):
    """获取指定报告详情"""
    if not is_valid_phone(phone):
        raise HTTPException(status_code=400, detail="手机号格式无效")
    report = get_report_by_id(report_id, phone)
    if not report:
        raise HTTPException(status_code=404, detail="报告不存在")
    rd = report["data"]
    rd.setdefault("_meta", {})
    rd["_meta"]["analyzed_at"] = report["created_at"]
    rd["_meta"]["is_full_report"] = report["is_free"] == 0
    rd["_report_id"] = report_id
    rd["_query_phone"] = phone
    return {"success": True, "data": rd}

@app.get("/api/reports/{report_id}/download")
async def download_report(report_id: int, phone: str = Query(..., description="手机号")):
    """下载Word格式报告"""
    from fastapi.responses import StreamingResponse
    
    if not is_valid_phone(phone):
        raise HTTPException(status_code=400, detail="手机号格式无效")
    report = get_report_by_id(report_id, phone)
    if not report:
        raise HTTPException(status_code=404, detail="报告不存在")
    
    is_free = report["is_free"] == 1
    buffer = generate_word_report(report["data"], report["brand"], report["industry"], is_free)
    
    filename = f"三三狐GEO_{report['brand']}_报告.docx"
    from urllib.parse import quote
    encoded_filename = quote(filename)
    
    return StreamingResponse(
        buffer,
        media_type="application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        headers={"Content-Disposition": f"attachment; filename*=UTF-8''{encoded_filename}"}
    )


# ==================== 后台管理接口 ====================

@app.post("/api/admin/upgrade")
async def admin_upgrade_phone(
    phone: str = Query(..., description="手机号"),
    days: int = Query(default=365, description="有效天数"),
    note: str = Query(default="", description="备注"),
    secret: str = Query(..., description="管理密钥")
):
    """后台开通付费用户（按手机号）"""
    if secret != ADMIN_SECRET:
        raise HTTPException(status_code=403, detail="无权限")
    if not is_valid_phone(phone):
        raise HTTPException(status_code=400, detail="手机号格式无效")
    
    upgrade_phone(phone, days, note)
    
    return {
        "success": True,
        "message": f"已为 {phone} 开通付费权限（{days}天）",
        "phone": phone,
        "days": days
    }

@app.post("/api/admin/downgrade")
async def admin_downgrade_phone(
    phone: str = Query(..., description="手机号"),
    secret: str = Query(..., description="管理密钥")
):
    """后台取消付费用户"""
    if secret != ADMIN_SECRET:
        raise HTTPException(status_code=403, detail="无权限")
    
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute("DELETE FROM premium_phones WHERE phone = ?", (phone,))
        conn.commit()
    
    return {"success": True, "message": f"已取消 {phone} 的付费权限"}

@app.get("/api/admin/premium-list")
async def admin_premium_list(secret: str = Query(..., description="管理密钥")):
    """查询所有付费手机号"""
    if secret != ADMIN_SECRET:
        raise HTTPException(status_code=403, detail="无权限")
    
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute("SELECT phone, expires_at, note, created_at FROM premium_phones ORDER BY created_at DESC")
        rows = cur.fetchall()
    
    return {
        "success": True,
        "count": len(rows),
        "data": [dict(r) for r in rows]
    }

@app.get("/api/admin/check-phone")
async def admin_check_phone(
    phone: str = Query(..., description="手机号"),
    secret: str = Query(..., description="管理密钥")
):
    """查询手机号付费状态"""
    if secret != ADMIN_SECRET:
        raise HTTPException(status_code=403, detail="无权限")
    
    is_premium = check_phone_premium(phone)
    
    # Also check today usage
    today = datetime.now().date().isoformat()
    with get_db_connection() as conn:
        cur = conn.cursor()
        cur.execute(
            "SELECT COUNT(*) as cnt FROM leads WHERE phone = ? AND date(created_at) = ?",
            (phone, today)
        )
        today_count = cur.fetchone()["cnt"]
    
    return {
        "success": True,
        "phone": phone,
        "is_premium": is_premium,
        "today_free_usage": today_count,
        "daily_limit": FREE_DAILY_LIMIT
    }

@app.get("/api/leads")
async def get_leads(limit: int = Query(default=50)):
    """获取免费诊断线索（管理用）"""
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute("SELECT * FROM leads ORDER BY created_at DESC LIMIT ?", (limit,))
        leads = [dict(row) for row in c.fetchall()]
    return {"success": True, "data": leads, "count": len(leads)}

